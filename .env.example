# GuruGlass Environment Variables
# Copy this file to .env and fill in your values

# ─── Admin Credentials ────────────────────────────────────────────────────────
# Change these before deploying!
ADMIN_USER=admin
ADMIN_PASS=guruglass2024

# ─── Session Secret ───────────────────────────────────────────────────────────
# Generate a random string: openssl rand -hex 32
SESSION_SECRET=change-this-to-a-random-secret-string

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000

# ─── Database ────────────────────────────────────────────────────────────────
# Optional: override the SQLite file path
# DB_PATH=./guruglass.db
